# API connectivity
RELEASEA_API_BASE_URL=http://host.k3d.internal:8070/api/v1
RELEASEA_WORKER_TOKEN=

# Worker identity
WORKER_ID=releasea-runner-prod-01
WORKER_NAME=releasea-runner-prod-01
WORKER_ENVIRONMENT=production
WORKER_NAMESPACE=releasea-workers-prod-01
WORKER_NAMESPACE_PREFIX=releasea-workers
WORKER_CLUSTER=k3d-local
WORKER_VERSION=dev
WORKER_TAGS=deploy,approved

# Queue and heartbeat
RABBITMQ_URL=amqp://releasea:releasea@localhost:5672/
WORKER_QUEUE=releasea.worker
WORKER_QUEUE_PREFETCH=1
WORKER_OPERATION_CLAIM_LEASE_SECONDS=120
WORKER_TOKEN_REFRESH_SKEW_SECONDS=120
WORKER_QUEUE_DLQ_ENABLE=true
WORKER_QUEUE_DLQ_NAME=releasea.worker.dead-letter
HEARTBEAT_INTERVAL_SECONDS=30

# Polling and runtime checks
WORKER_POLL_SECONDS=20
WORKER_POLL_LIMIT=10
WORKER_RUNTIME_SECONDS=5
WORKER_DESIRED_AGENTS=0

# Deploy behavior
WORKER_DEPLOY_RETRY_DELAY_SECONDS=6
WORKER_DEPLOY_RETRY_MAX_ATTEMPTS=3
WORKER_DEPLOY_READY_TIMEOUT_SECONDS=420
WORKER_DEPLOY_READY_POLL_SECONDS=5
WORKER_BLUE_GREEN_OBSERVATION_SECONDS=30

# Auto-deploy monitor
WORKER_AUTODEPLOY_ENABLED=1
WORKER_AUTODEPLOY_SECONDS=60
WORKER_AUTODEPLOY_LEASE_SECONDS=120
WORKER_AUTODEPLOY_ERROR_COOLDOWN_SECONDS=60
WORKER_AUTODEPLOY_QUEUE_ERROR_COOLDOWN_SECONDS=30
WORKER_AUTODEPLOY_PENDING_SECONDS=130

# Pause when idle
WORKER_PAUSE_IDLE_DEFAULT_SECONDS=3600
WORKER_PAUSE_IDLE_RESUME_WINDOW_SECONDS=120

# Cleanup/curator
WORKER_CURATOR_SECONDS=60
WORKER_CURATOR_MAX_SECONDS=600

# Routing and static workloads
RELEASEA_INTERNAL_DOMAIN=releasea.internal
RELEASEA_EXTERNAL_DOMAIN=releasea.external
RELEASEA_INTERNAL_GATEWAY=istio-system/releasea-internal-gateway
RELEASEA_EXTERNAL_GATEWAY=istio-system/releasea-external-gateway
RELEASEA_STATIC_SITE_PREFIX=sites
RELEASEA_STATIC_NGINX_SERVICE=releasea-static-nginx
RELEASEA_STATIC_NGINX_NAMESPACE=releasea-system
RELEASEA_NAMESPACE_MAPPING=

# Optional deployment metadata
WORKER_DEPLOYMENT_NAME=
WORKER_DEPLOYMENT_NAMESPACE=

# MinIO (static site assets)
RELEASEA_MINIO_ENDPOINT=releasea-minio.releasea-system.svc.cluster.local:9000
RELEASEA_MINIO_ACCESS_KEY=releasea
RELEASEA_MINIO_SECRET_KEY=releaseaadmin
RELEASEA_MINIO_BUCKET=releasea-static
RELEASEA_MINIO_SECURE=false

# Optional RabbitMQ TLS
RABBITMQ_TLS_MODE=auto
RABBITMQ_TLS_REQUIRE=false
RABBITMQ_ALLOW_INSECURE_IN_PRODUCTION=false
RABBITMQ_TLS_ENABLE=false
RABBITMQ_TLS_SERVER_NAME=
RABBITMQ_TLS_CA_PATH=
RABBITMQ_TLS_CERT_PATH=
RABBITMQ_TLS_KEY_PATH=
RABBITMQ_TLS_INSECURE=false
